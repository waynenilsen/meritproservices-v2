#!/usr/bin/env bash
set -euo pipefail

# Conductor workspace bootstrap script
# Uses CONDUCTOR_PORT to deconflict the Next.js dev server port across workspaces

PORT="${CONDUCTOR_PORT:-3000}"

echo "Setting up workspace: ${CONDUCTOR_WORKSPACE_NAME:-unknown} (port $PORT)"

# Write .env.local with workspace-specific port
cat > .env.local <<EOF
PORT=$PORT
EOF

# Append local secrets if available
SECRETS_FILE="$HOME/.secrets/meritproservices.env"
if [[ -f "$SECRETS_FILE" ]]; then
  echo "" >> .env.local
  cat "$SECRETS_FILE" >> .env.local
  echo "Loaded secrets from $SECRETS_FILE"
else
  echo "No secrets file found at $SECRETS_FILE (skipping)"
fi

# Install dependencies and build native modules (better-sqlite3 needs node-gyp)
bun install
npx --yes node-gyp rebuild --directory=node_modules/better-sqlite3

# Generate Prisma client
bunx prisma generate

# Run database migrations
bunx prisma migrate deploy
