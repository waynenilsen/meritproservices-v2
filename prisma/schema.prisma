generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Session {
  id        String    @id // cuid
  email     String?
  createdAt DateTime  @default(now())
  expiresAt DateTime
}

model MagicLink {
  id        String   @id // cuid
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  sessionId String
  createdAt DateTime @default(now())
}
